# ============================================================
# 미니PC에서 사용: 이 파일을 복사해 .env 를 만든 뒤 값을 채우세요.
#   Windows: copy .env.example .env
#   Mac/Linux: cp .env.example .env
# ============================================================
# .env가 암호화/권한 문제로 읽히지 않을 때: dashboard 폴더에 새 .env 파일을
# 생성한 뒤 기존에 쓰던 값들을 다시 복사해 넣으세요. (OneDrive 등 동기화 시 발생 가능)
# ============================================================

# 업비트 Open API (업비트 웹 > 마이페이지 > Open API 관리에서 발급)
UPBIT_ACCESS_KEY=
UPBIT_SECRET_KEY=
# 미니 PC용 대체 키 (401 시 자동 전환, 미설정 시 메인 키만 사용)
UPBIT_ACCESS_KEY_MINI=
UPBIT_SECRET_KEY_MINI=

# API 키 파일 경로 (config.json 사용 시)
CONFIG_PATH=

# 서버 포트 (기본 3000)
PORT=

# ----------------------------------------
# Discord 매매 봇 (제어 패널 / 체결 알림)
# ----------------------------------------
DISCORD_TOKEN=
DISCORD_BOT_TOKEN=
CHANNEL_ID=
DISCORD_CHANNEL_ID=
# 본인 디스코드 고유 ID만 모든 버튼/명령 제어 가능 (여기에_본인_ID_입력)
ADMIN_ID=
DISCORD_ADMIN_ID=
# 역할 C(인프라 관리자) 전용 — 시스템 업데이트/재기동 버튼 (미설정 시 ADMIN_ID 사용)
ADMIN_DISCORD_ID=

# 선택: 체결 알림 전용 채널 (미설정 시 CHANNEL_ID에 함께 전송)
TRADING_LOG_CHANNEL_ID=
# 선택: 4시간마다 시황 브리핑 전송 채널
AI_ANALYSIS_CHANNEL_ID=

# 리팩터 discord-operator: CHANNEL_ID 또는 아래 채널 ID 사용. CLIENT_ID/GUILD_ID는 선택.
# DISCORD_OPERATOR_CHANNEL_ID=
# DISCORD_CLIENT_ID=
# DISCORD_GUILD_ID=

# ----------------------------------------
# MarketSearchEngine (시황 분석 봇) 전용
# ----------------------------------------
MARKET_BOT_TOKEN=
MARKET_SEARCH_ENGINE_TOKEN=
MARKET_SEARCH_ENGINE_CHANNEL_ID=
MARKET_CHANNEL_ID=
DASHBOARD_URL=

# ----------------------------------------
# OpenAI (ChatGPT) — 하루치 로그 분석에 사용 (선택)
# ----------------------------------------
# 설정 시: Discord "하루치 로그 (일 단위) 분석" 버튼이 ChatGPT로 동작. 미설정 시 Gemini 사용.
# 발급: https://platform.openai.com/api-keys (본인 OpenAI 계정 로그인 후 Create API key)
OPENAI_API_KEY=
# 사용할 모델 (기본: gpt-4o-mini). gpt-4o 등으로 변경 가능
# OPENAI_LOG_MODEL=gpt-4o-mini

# ----------------------------------------
# Gemini (급등주 AI 추천, Google AI Studio 발급)
# ----------------------------------------
# Google AI Studio에서 발급한 API 키 (필수). 예: GEMINI_API_KEY=AIza...
GEMINI_API_KEY=
# (미사용) 모델은 코드에서 gemini-2.5-flash 로 고정. 사용 가능 목록: npm run list-gemini-models
# GEMINI_MODEL=gemini-2.5-flash
# 오류 원인 확인용: 1 또는 true 로 설정하면 콘솔에 상세 로그 출력
# GEMINI_DEBUG=1

# ----------------------------------------
# 선택 환경
# ----------------------------------------
MEME_PAGE_ONLY=
ORCH_PAGE_ONLY=
