  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "node server.js",
    "build:refactor": "tsc -p tsconfig.refactor.json",
    "start:refactor": "node dist-refactor/apps/api-server/src/index.js",
    "pm2:refactor": "npm run build:refactor && pm2 start ecosystem.refactor.config.cjs",
    "pm2:refactor:restart": "npm run build:refactor && pm2 restart ecosystem.refactor.config.cjs",
    "pm2:refactor:stop": "node scripts/pm2-delete-if-exists.js delete api-server discord-operator market-bot",
    "pm2:refactor:logs": "pm2 logs api-server discord-operator market-bot",
    "start:agent": "node discord_agent.js",
    "start:all": "pm2 start ecosystem.config.cjs",
    "stop:all": "node scripts/pm2-delete-if-exists.js delete upbit-bot MarketSearchEngine",
    "restart:all": "pm2 restart ecosystem.config.cjs",
    "pm2:main": "npm run build:refactor && node scripts/pm2-delete-if-exists.js delete api-server && pm2 start ecosystem.main.config.cjs && node --no-deprecation scripts/pm2-status-table.js",
    "pm2:main:restart": "npm run build:refactor && node scripts/pm2-delete-if-exists.js delete api-server && pm2 restart ecosystem.main.config.cjs && node --no-deprecation scripts/pm2-status-table.js",
    "pm2:main:stop": "node scripts/pm2-delete-if-exists.js delete api-server upbit-bot MarketSearchEngine discord-operator market-bot",
    "pm2:status": "node --no-deprecation scripts/pm2-status-table.js",
    "log": "pm2 logs",
    "pm2:start": "npx pm2 start ecosystem.config.cjs",
    "pm2:start:engine": "npx pm2 start ecosystem.engine.config.cjs",
    "pm2:stop": "node scripts/pm2-delete-if-exists.js stop upbit-bot MarketSearchEngine",
    "pm2:restart": "npx pm2 restart ecosystem.config.cjs",
    "pm2:restart:engine": "npx pm2 restart ecosystem.engine.config.cjs",
    "pm2:logs": "npx pm2 logs --lines 300",
    "pm2:logs:err": "npx pm2 logs upbit-bot --err --lines 300",
    "pm2:logs:gemini": "node scripts/show-gemini-diagnostic-log.js",
    "list-gemini-models": "node scripts/list-gemini-models.js",
    "check-api-errors": "node scripts/check-api-errors.js"
